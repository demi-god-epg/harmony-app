{
  "name": "@harmony-lifebond/mobile",
  "version": "1.0.0",
  "description": "Harmony Lifebond Mobile App (React Native / Flutter)",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "web": "react-native-web start",
    "build:android": "cd android && gradlew bundleRelease",
    "build:ios": "xcodebuild -workspace ios/HarmonyLifebond.xcworkspace -scheme HarmonyLifebond -configuration Release",
    "lint": "eslint src",
    "format": "prettier --write src/",
    "test": "jest"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "react-native-screens": "^3.0.0",
    "@react-navigation/native": "^6.0.0",
    "@react-navigation/bottom-tabs": "^6.0.0",
    "react-native-gesture-handler": "^2.0.0",
    "react-native-reanimated": "^3.0.0",
    "@react-native-camera-roll/camera-roll": "^6.0.0",
    "react-native-permissions": "^3.0.0",
    "react-native-qrcode-svg": "^6.0.0",
    "axios": "^1.0.0",
    "@tanstack/react-query": "^5.0.0",
    "zustand": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.72.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "jest": "^29.0.0",
    "@react-native-community/eslint-config": "^3.0.0"
  }
}
