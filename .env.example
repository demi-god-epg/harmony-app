# Environment Configuration Template
# Copy this file to .env and fill in your values

# Application Environment
NODE_ENV=development
PORT=3001
APP_NAME=Harmony Lifebond
APP_VERSION=1.0.0

# Database Configuration
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=harmony_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/harmony_db

# OR MongoDB
# MONGODB_URI=mongodb://localhost:27017/harmony

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_REFRESH_EXPIRY=30d

# OTP Configuration
OTP_SECRET=change-this-otp-secret
OTP_EXPIRY=10m
OTP_LENGTH=6

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Harmony Lifebond
SMTP_FROM_EMAIL=noreply@harmonylifebond.com

# SMS Configuration
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Mobile Money Integration
MTN_MOBILE_MONEY_API_KEY=your-mtn-api-key
MTN_MOBILE_MONEY_USER_ID=your-user-id
MTN_MOBILE_MONEY_API_SECRET=your-api-secret
MTN_PRIMARY_KEY=your-primary-key
MTN_SECONDARY_KEY=your-secondary-key
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com

# Vodafone Cash
VODAFONE_API_KEY=your-vodafone-key
VODAFONE_MERCHANT_ID=your-merchant-id
VODAFONE_API_SECRET=your-secret
VODAFONE_BASE_URL=https://sandbox.vodafone-cash.com

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=harmony-lifebond-bucket
AWS_S3_URL=https://harmony-lifebond-bucket.s3.amazonaws.com

# Google Cloud Storage
GCS_PROJECT_ID=your-gcs-project
GCS_BUCKET_NAME=harmony-bucket
GCS_KEY_FILE=./path-to-gcs-key.json

# Sentry Error Tracking
SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# Session Configuration
SESSION_SECRET=change-this-session-secret
SESSION_TIMEOUT=3600000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx
UPLOAD_DIR=./uploads

# Payment Configuration
PAYMENT_CURRENCY=GHS
PAYMENT_TIMEOUT=300

# Web App Configuration
VITE_API_URL=http://localhost:3001/api
VITE_APP_NAME=Harmony Lifebond
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development
VITE_LOG_LEVEL=info

# Mobile App Configuration
REACT_NATIVE_API_URL=http://localhost:3001/api
REACT_NATIVE_SENTRY_KEY=your-sentry-key

# Admin Configuration
ADMIN_EMAIL=admin@harmonylifebond.com
ADMIN_DEFAULT_PASSWORD=change-this-password

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Feature Flags
FEATURE_BUSINESS_HUB=true
FEATURE_EDUCATION_PORTAL=true
FEATURE_SAVINGS_GROUPS=false
FEATURE_LOAN_SYSTEM=false

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System under maintenance. Please try again later.

# API Documentation
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs
